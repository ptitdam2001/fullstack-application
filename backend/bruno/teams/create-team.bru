meta {
  name: Create Team
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/team
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "FC Example",
    "color": "#1a2b3c"
  }
}

script:post-response {
  if (res.status === 200 && res.body) {
    bru.setVar("teamId", res.body);
  }
}
