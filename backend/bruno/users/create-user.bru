meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/user
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "firstname": "John",
    "lastname": "Doe",
    "email": "john.doe@example.com",
    "password": "password",
    "role": "COACH"
  }
}

script:post-response {
  if (res.status === 200 && res.body._id) {
    bru.setVar("userId", res.body._id);
  }
}
