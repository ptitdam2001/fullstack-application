meta {
  name: Create Group
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/group
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "phaseId": "{{phaseId}}",
    "name": "Poule A",
    "matchMode": "HOME_AND_AWAY",
    "teamIds": ["{{teamId}}"]
  }
}

script:post-response {
  if (res.status === 201 && res.body.id) {
    bru.setVar("groupId", res.body.id);
  }
}
