    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.1",
    "esbuild": "0.27.3",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "prettier": "@repo/prettier-config"
}
