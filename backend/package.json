{
  "name": "openapi-express-ts",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "check:type": "tsc --noEmit",
    "generate:prisma": "prisma generate",
    "format:prisma": "prisma format",
    "build": "esbuild index.ts --platform=node --format=esm --bundle --packages=external --outfile=./dist/index.js",
    "start:dev": "tsx watch index.ts",
    "start:prod": "node ./dist/index.js",
    "lint": "eslint .",
    "check:format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "6.19",
    "ajv-formats": "^2.1.1",
    "bcrypt": "^5.1.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "openapi-backend": "^5.16.1",
    "prisma": "^6.19.2",
    "winston": "^3.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  },
  "devDependencies": {
    "@repo/eslint-config": "file:../tooling/eslint-config",
