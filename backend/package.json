{
  "name": "openapi-express-ts",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "check:type": "tsc --noEmit",
    "generate:prisma": "prisma generate",
    "format:prisma": "prisma format",
    "build": "esbuild index.ts --platform=node --format=esm --bundle --packages=external --outfile=./dist/index.js",
    "start:dev": "tsx watch index.ts",
    "start:prod": "node ./dist/index.js",
    "lint": "eslint .",
    "check:format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:functional": "vitest run --config vitest.functional.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "~6.19.3",
    "ajv-formats": "^3.0.1",
    "bcrypt": "^5.1.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "openapi-backend": "^5.17.0",
    "prisma": "^6.19.3",
    "winston": "^3.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@repo/eslint-config": "file:../tooling/eslint-config",
    "@repo/prettier-config": "file:../tooling/prettier-config",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "esbuild": "0.28.1",
    "eslint": "^10.5.0",
    "mongodb": "^7.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "prettier": "@repo/prettier-config"
}
