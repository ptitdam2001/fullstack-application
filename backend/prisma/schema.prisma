// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CHAMPIONSHIP
// ─────────────────────────────────────────

enum AgeCategory {
  U9
  U11
  U13
  U15
  U18
  Senior
}

type PointsConfig {
  win     Int
  draw    Int
  loss    Int
  forfeit Int
}

model Championship {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  ageCategory  AgeCategory
  season       String
  startDate    DateTime?
  endDate      DateTime?
  pointsConfig PointsConfig
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

enum Role {
  ADMIN
  COACH
  REFEREE
  PLAYER
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  lastName  String?
  firstName String
  email     String   @unique
  password  String
  avatar    String?
  role      Role     @default(COACH)
  createdAt DateTime @default(now())

  player Player?
}

// ─────────────────────────────────────────
// AREA
// ─────────────────────────────────────────

model Area {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// ─────────────────────────────────────────
// EMBEDDED TYPES
// ─────────────────────────────────────────

// Area dénormalisée dans Team et Match (snapshot au moment de l'enregistrement)
type EmbeddedArea {
  id        String
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// Score d'une équipe dans un match (embarqué dans Match)
type EmbeddedMatchTeam {
  teamId String @db.ObjectId
  score  Int    @default(0)
}

// ─────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────

model Team {
  id    String         @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  color String?
  areas EmbeddedArea[]

  players    Player[]
  matchTeams MatchTeam[]
}

// ─────────────────────────────────────────
// PLAYER
// ─────────────────────────────────────────

model Player {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String  @unique @db.ObjectId
  teamId    String  @db.ObjectId
  jersey    Int?
  position  String?
  lastname  String
  firstname String
  avatar    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────

model Match {
  id    String              @id @default(auto()) @map("_id") @db.ObjectId
  date  DateTime?
  area  EmbeddedArea
  // Les 2 équipes + scores sont embarqués directement dans le document
  teams EmbeddedMatchTeam[]

  // Relation Prisma pour permettre les requêtes match <-> team
  matchTeams MatchTeam[]

  @@map("games")
}

// Liaison explicite Match <-> Team
// Permet à Prisma de résoudre les relations et de faire des requêtes
// du type : prisma.team.findMany({ include: { matchTeams: { include: { match: true } } } })
model MatchTeam {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  matchId String @db.ObjectId
  teamId  String @db.ObjectId
  score   Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@map("gameTeams")
}
