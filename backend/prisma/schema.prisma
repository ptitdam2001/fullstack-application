// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CHAMPIONSHIP
// ─────────────────────────────────────────

enum AgeCategory {
  U9
  U11
  U13
  U15
  U18
  Senior
}

type PointsConfig {
  win     Int
  draw    Int
  loss    Int
  forfeit Int
}

model Championship {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  ageCategory  AgeCategory
  season       String
  startDate    DateTime?
  endDate      DateTime?
  pointsConfig PointsConfig

  phases Phase[]
}

// ─────────────────────────────────────────
// PHASE
// ─────────────────────────────────────────

enum PhaseType {
  GROUP
  KNOCKOUT
}

model Phase {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  championshipId String    @db.ObjectId
  type           PhaseType
  order          Int
  name           String?

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  groups       Group[]

  @@map("phases")
}

// ─────────────────────────────────────────
// GROUP (poule)
// ─────────────────────────────────────────

enum MatchMode {
  SINGLE
  HOME_AND_AWAY
}

model Group {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  phaseId   String    @db.ObjectId
  name      String
  matchMode MatchMode
  teamIds   String[]  @db.ObjectId

  phase   Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  matches Match[]

  @@map("poules")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  lastName              String?
  firstName             String
  email                 String    @unique
  password              String
  avatar                String?
  isAdmin               Boolean   @default(false)
  isActive              Boolean   @default(false)
  isBlocked             Boolean   @default(false)
  isReferee             Boolean   @default(false)
  loginAttempts         Int       @default(0)
  activationToken       String?
  activationTokenExpiry DateTime?
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime  @default(now())

  players      Player[]
  userTeams    UserTeam[]
  userMatches  UserMatch[]
  joinRequests TeamJoinRequest[]
}

// ─────────────────────────────────────────
// AREA
// ─────────────────────────────────────────

model Area {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// ─────────────────────────────────────────
// EMBEDDED TYPES
// ─────────────────────────────────────────

// Area dénormalisée dans Team et Match (snapshot au moment de l'enregistrement)
type EmbeddedArea {
  id        String
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// ─────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────

model Team {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  color       String?
  areas       EmbeddedArea[]
  ageCategory AgeCategory?

  players      Player[]
  userTeams    UserTeam[]
  joinRequests TeamJoinRequest[]
}

// ─────────────────────────────────────────
// PLAYER (profil joueur dans une équipe)
// ─────────────────────────────────────────

model Player {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String  @db.ObjectId
  teamId   String  @db.ObjectId
  jersey   Int?
  position String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("players")
}

// ─────────────────────────────────────────
// USER <-> TEAM (coaches et joueurs)
// ─────────────────────────────────────────

enum TeamRole {
  COACH
  PLAYER
}

// Liaison User <-> Team avec rôle contextuel.
// @@unique([userId, teamId, role]) permet à un même user d'être COACH et PLAYER de la même équipe.
model UserTeam {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  teamId String   @db.ObjectId
  role   TeamRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId, role])
  @@map("userTeams")
}

// ─────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────

enum MatchStatus {
  SCHEDULED
  PLAYED
  FORFEITED
  CANCELLED
}

model Match {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String?     @db.ObjectId
  status      MatchStatus @default(SCHEDULED)
  scheduledAt DateTime?
  area        EmbeddedArea
  homeTeamId  String      @db.ObjectId
  awayTeamId  String      @db.ObjectId
  homeGoals   Int?
  awayGoals   Int?
  forfeitedBy String?     @db.ObjectId

  group       Group?    @relation(fields: [groupId], references: [id])
  userMatches UserMatch[]

  @@map("games")
}

// ─────────────────────────────────────────
// TEAM JOIN REQUESTS
// ─────────────────────────────────────────

enum JoinRequestStatus {
  PENDING
  APPROVED
  REFUSED
}

model TeamJoinRequest {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  teamId        String            @db.ObjectId
  requestedRole TeamRole          @default(PLAYER)
  status        JoinRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("teamJoinRequests")
}

// ─────────────────────────────────────────
// USER <-> MATCH (arbitres)
// ─────────────────────────────────────────

// Liaison User <-> Match pour les arbitres d'un match.
model UserMatch {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  matchId String @db.ObjectId

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("userMatches")
}
