// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CHAMPIONSHIP
// ─────────────────────────────────────────

enum Genre {
  MALE
  FEMALE
  MIXED
}

model AgeCategory {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  label     String
  genre     Genre
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  teams         Team[]
  championships Championship[]

  @@unique([label, genre])
  @@map("ageCategories")
}

type PointsConfig {
  win     Int
  draw    Int
  loss    Int
  forfeit Int
}

model Championship {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  ageCategoryId   String      @db.ObjectId
  season          String
  startDate    DateTime?
  endDate      DateTime?
  pointsConfig PointsConfig
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  ageCategory AgeCategory @relation(fields: [ageCategoryId], references: [id])
  phases      Phase[]

  @@map("championships")
}

// ─────────────────────────────────────────
// PHASE
// ─────────────────────────────────────────

enum PhaseType {
  GROUP
  KNOCKOUT
}

model Phase {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  championshipId String    @db.ObjectId
  type           PhaseType
  order          Int
  name           String?
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  groups       Group[]

  @@unique([championshipId, order])
  @@map("phases")
}

// ─────────────────────────────────────────
// GROUP (poule)
// ─────────────────────────────────────────

enum MatchMode {
  SINGLE
  HOME_AND_AWAY
}

model Group {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  phaseId   String    @db.ObjectId
  name      String
  matchMode MatchMode
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  phase      Phase       @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  matches    Match[]
  groupTeams GroupTeam[]

  @@map("groups")
}

model GroupTeam {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  groupId String @db.ObjectId
  teamId  String @db.ObjectId

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([groupId, teamId])
  @@map("groupTeams")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  lastName              String?
  firstName             String
  email                 String    @unique
  password              String
  avatar                String?
  isAdmin               Boolean   @default(false)
  isActive              Boolean   @default(false)
  isBlocked             Boolean   @default(false)
  isReferee             Boolean   @default(false)
  loginAttempts         Int       @default(0)
  activationToken       String?
  activationTokenExpiry DateTime?
  resetToken            String?
  resetTokenExpiry      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  players      Player[]
  userTeams    UserTeam[]
  userMatches  UserMatch[]
  joinRequests TeamJoinRequest[]

  @@map("users")
}

// ─────────────────────────────────────────
// AREA
// ─────────────────────────────────────────

model Area {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
  updatedAt DateTime @updatedAt

  @@map("areas")
}

// ─────────────────────────────────────────
// EMBEDDED TYPES
// ─────────────────────────────────────────

// Area dénormalisée dans Team et Match (snapshot au moment de l'enregistrement)
type EmbeddedArea {
  id        String
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// ─────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────

model Team {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  color           String?
  areas           EmbeddedArea[]
  ageCategoryId   String?        @db.ObjectId

  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  ageCategory  AgeCategory?      @relation(fields: [ageCategoryId], references: [id])
  players      Player[]
  userTeams    UserTeam[]
  joinRequests TeamJoinRequest[]
  // Match participations (home/away) — named to disambiguate two relations to Match
  homeMatches      Match[] @relation("HomeTeam")
  awayMatches      Match[] @relation("AwayTeam")
  forfeitedMatches Match[] @relation("ForfeitTeam")
  // Group memberships via junction (replaces embedded teamIds array)
  groupTeams GroupTeam[]

  @@map("teams")
}

// ─────────────────────────────────────────
// PLAYER (profil joueur dans une équipe)
// ─────────────────────────────────────────
//
// Distinction intentionnelle avec UserTeam(PLAYER) :
//   UserTeam(role=PLAYER) = droits d'accès à l'équipe (membership)
//   Player                = profil football (jersey, position)
//
// Invariant applicatif : tout Player doit avoir un UserTeam(PLAYER) correspondant
// sur le même (userId, teamId). L'inverse n'est pas vrai — un membre peut ne pas
// encore avoir de profil football assigné.
// Cette contrainte est vérifiée dans les use cases, pas en DB.

model Player {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String  @db.ObjectId
  teamId   String  @db.ObjectId
  jersey    Int?
  position  String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("players")
}

// ─────────────────────────────────────────
// USER <-> TEAM (coaches et joueurs)
// ─────────────────────────────────────────

enum TeamRole {
  COACH
  PLAYER
}

// Liaison User <-> Team avec rôle contextuel.
// @@unique([userId, teamId, role]) permet à un même user d'être COACH et PLAYER de la même équipe.
model UserTeam {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  teamId String   @db.ObjectId
  role   TeamRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId, role])
  @@map("userTeams")
}

// ─────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────

enum MatchStatus {
  SCHEDULED
  PLAYED
  FORFEITED
  CANCELLED
}

model Match {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String?     @db.ObjectId
  status      MatchStatus  @default(SCHEDULED)
  scheduledAt DateTime?
  area        EmbeddedArea?
  homeTeamId  String       @db.ObjectId
  awayTeamId  String      @db.ObjectId
  homeGoals   Int?
  awayGoals   Int?
  forfeitedBy String?      @db.ObjectId
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  group           Group?  @relation(fields: [groupId], references: [id])
  userMatches     UserMatch[]
  // Named relations to disambiguate multiple FK to Team
  homeTeam        Team    @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team    @relation("AwayTeam", fields: [awayTeamId], references: [id])
  forfeitingTeam  Team?   @relation("ForfeitTeam", fields: [forfeitedBy], references: [id])

  @@map("matches")
}

// ─────────────────────────────────────────
// TEAM JOIN REQUESTS
// ─────────────────────────────────────────

enum JoinRequestStatus {
  PENDING
  APPROVED
  REFUSED
}

model TeamJoinRequest {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  teamId        String            @db.ObjectId
  requestedRole TeamRole          @default(PLAYER)
  status        JoinRequestStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("teamJoinRequests")
}

// ─────────────────────────────────────────
// USER <-> MATCH (arbitres)
// ─────────────────────────────────────────

// Liaison User <-> Match pour les arbitres d'un match.
model UserMatch {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  matchId String @db.ObjectId

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("userMatches")
}
