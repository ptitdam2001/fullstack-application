// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// CHAMPIONSHIP
// ─────────────────────────────────────────

enum AgeCategory {
  U9
  U11
  U13
  U15
  U18
  Senior
}

type PointsConfig {
  win     Int
  draw    Int
  loss    Int
  forfeit Int
}

model Championship {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  ageCategory  AgeCategory
  season       String
  startDate    DateTime?
  endDate      DateTime?
  pointsConfig PointsConfig
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  lastName  String?
  firstName String
  email     String   @unique
  password  String
  avatar    String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  players     Player[]
  userTeams   UserTeam[]
  userMatches UserMatch[]
}

// ─────────────────────────────────────────
// AREA
// ─────────────────────────────────────────

model Area {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// ─────────────────────────────────────────
// EMBEDDED TYPES
// ─────────────────────────────────────────

// Area dénormalisée dans Team et Match (snapshot au moment de l'enregistrement)
type EmbeddedArea {
  id        String
  name      String?
  address   String
  city      String
  longitude Float
  latitude  Float
}

// Score d'une équipe dans un match (embarqué dans Match)
type EmbeddedMatchTeam {
  teamId String @db.ObjectId
  score  Int    @default(0)
}

// ─────────────────────────────────────────
// TEAM
// ─────────────────────────────────────────

model Team {
  id    String         @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  color String?
  areas EmbeddedArea[]

  players    Player[]
  matchTeams MatchTeam[]
  userTeams  UserTeam[]
}

// ─────────────────────────────────────────
// PLAYER (profil joueur dans une équipe)
// ─────────────────────────────────────────

model Player {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  userId   String  @db.ObjectId
  teamId   String  @db.ObjectId
  jersey   Int?
  position String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("players")
}

// ─────────────────────────────────────────
// USER <-> TEAM (coaches et joueurs)
// ─────────────────────────────────────────

enum TeamRole {
  COACH
  PLAYER
}

// Liaison User <-> Team avec rôle contextuel.
// @@unique([userId, teamId, role]) permet à un même user d'être COACH et PLAYER de la même équipe.
model UserTeam {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  teamId String   @db.ObjectId
  role   TeamRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId, role])
  @@map("userTeams")
}

// ─────────────────────────────────────────
// MATCH
// ─────────────────────────────────────────

model Match {
  id    String              @id @default(auto()) @map("_id") @db.ObjectId
  date  DateTime?
  area  EmbeddedArea
  // Les 2 équipes + scores sont embarqués directement dans le document
  teams EmbeddedMatchTeam[]

  // Relation Prisma pour permettre les requêtes match <-> team
  matchTeams  MatchTeam[]
  userMatches UserMatch[]

  @@map("games")
}

// Liaison explicite Match <-> Team
model MatchTeam {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  matchId String @db.ObjectId
  teamId  String @db.ObjectId
  score   Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@map("gameTeams")
}

// ─────────────────────────────────────────
// USER <-> MATCH (arbitres)
// ─────────────────────────────────────────

// Liaison User <-> Match pour les arbitres d'un match.
model UserMatch {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  matchId String @db.ObjectId

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@map("userMatches")
}
