{
  "name": "application-material",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "(cd ../design-system && pnpm build) && vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "gen:sdk": "orval --config ./orval.config.ts",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:types": "tsc --noEmit",
    "check:format": "prettier -c .",
    "check:lint": "eslint .",
    "check:dead-code": "knip",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@repo/design-system": "workspace:*",
    "@repo/form-factory": "workspace:*",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "axios": "1.13.5",
    "country-flag-icons": "^1.6.14",
    "dayjs": "^1.11.19",
    "flat": "^6.0.1",
    "lucide-react": "^0.575.0",
    "react": "19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-intl": "8.1.3",
    "react-router": "7.13.1",
    "recharts": "^3.8.1",
    "tailwind-scrollbar": "4.0.2",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "zod": "4.3.6"
  },
  "prettier": "@repo/prettier-config",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.3.0",
    "@repo/eslint-config": "file:../../tooling/eslint-config",
    "@repo/prettier-config": "file:../../tooling/prettier-config",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "autoprefixer": "10.4.24",
    "eslint": "10.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-storybook": "10.4.2",
    "globals": "17.3.0",
    "jsdom": "28.1.0",
    "knip": "^5.85.0",
    "msw": "2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "orval": "8.4.2",
    "playwright": "1.58.2",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "storybook": "10.4.2",
    "storybook-addon-remix-react-router": "6.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "engines": {
    "node": ">=10",
    "pnpm": ">=3"
  }
}
