{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "baseUrl": ".",
    "paths": {
      "@Auth/*": ["./src/Auth/*", "./src/Auth/"],
      "@Layouts/*": ["./src/Layouts/*", "./src/Layouts/"],
      "@Theme/*": ["./src/Theme/*", "./src/Theme/"],
      "@Common/*": ["./src/Common/*", "./src/Common/"],
      "@Teams": ["./src/Teams/index.ts"],
      "@Teams/*": ["./src/Teams/*", "./src/Teams/"],
      "@Player": ["./src/Player/index.ts"],
      "@Player/*": ["./src/Player/*", "./src/Player/"],
      "@Game": ["./src/Game/index.ts"],
      "@Game/*": ["./src/Game/*", "./src/Game/"],
      "@Calendar": ["./src/Calendar/index.ts"],
      "@Calendar/*": ["./src/Calendar/*", "./src/Calendar/"],
      "@Application": ["./src/Application/index.ts"],
      "@Application/*": ["./src/Application/*", "./src/Application/"],
      "@Settings": ["./src/Settings/index.ts"],
      "@Settings/*": ["./src/Settings/*", "./src/Settings/"],
      "@Dashboard": ["./src/Dashboard/index.ts"],
      "@Dashboard/*": ["./src/Dashboard/*", "./src/Dashboard/"],
      "@Admin": ["./src/Admin/index.ts"],
      "@Admin/*": ["./src/Admin/*", "./src/Admin/"],
      "@Sdk/*": ["./src/sdk/generated/", "./src/sdk/generated/*"],
      "@Config/*": ["./config/*", "./config/"],
      "@I18n/*": ["src/I18n/*", "src/I18n"],
      "@/*": ["./src/*"],
      "@repo/design-system": ["../design-system/src/index.ts"],
      "@repo/design-system/*": ["../design-system/src/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": ["src", "tests"]
}
